import { Router, Request, Response } from 'express';
import { PrismaClient } from '@prisma/client';
import { accountService } from '../services/accountService';
import { runJimengCommand } from '../utils/cliRunner';
import { v4 as uuidv4 } from 'uuid';
import multer from 'multer';
import fs from 'fs';

const router = Router();
const prisma = new PrismaClient();
const upload = multer({ dest: 'temp_uploads/' });

// 简单的 Bearer Token 验证 Middleware
const apiKeyAuth = async (req: Request, res: Response, next: any) => {
  const authHeader = req.headers.authorization;
  if (!authHeader || !authHeader.startsWith('Bearer ')) {
    return res.status(401).json({ error: { message: 'Missing Authorization header' } });
  }
  
  const token = authHeader.split(' ')[1];
  const apiKey = await prisma.apiKey.findUnique({
    where: { key: token, isActive: true }
  });

  if (!apiKey) {
    return res.status(401).json({ error: { message: 'Invalid API Key' } });
  }

  // Inject user info
  (req as any).apiUserId = apiKey.id;
  next();
};

/**
 * 提取 URL 的公共方法
 */
function extractResultUrl(stdout: string, type: 'image' | 'video'): string {
  try {
    const jsonStr = stdout.substring(stdout.indexOf('{'), stdout.lastIndexOf('}') + 1);
    const result = JSON.parse(jsonStr);
    if (type === 'image' && result.result_json?.images?.[0]?.image_url) {
      return result.result_json.images[0].image_url;
    }
    if (type === 'video' && result.result_json?.videos?.[0]?.video_url) {
      return result.result_json.videos[0].video_url;
    }
    throw new Error("Missing url in output JSON\nRaw output: " + stdout);
  } catch (parseErr) {
    const regex = type === 'image' 
      ? /https:\/\/[^\s"'<>]+\.(png|jpg|jpeg|webp)(?:\?[^\s"'<>]+)?/i
      : /https:\/\/[^\s"'<>]+\.(mp4)(?:\?[^\s"'<>]+)?/i;
    const urlMatch = stdout.match(regex); 
    if (urlMatch) {
       return urlMatch[0];
    } else {
       throw new Error(`Unable to parse result URL from CLI output. Parse Error: ${(parseErr as Error).message}\nRaw Output: ${stdout.substring(0, 500)}`);
    }
  }
}

/**
 * POST /v1/images/generations 
 * 合并生图功能 (文生图 + 图生图)
 */
router.post('/images/generations', apiKeyAuth, upload.array('images', 10), async (req: Request, res: Response) => {
  try {
    const { prompt, size, model, resolution_type } = req.body;
    const files = (req.files as Express.Multer.File[]) || [];
    const hasImages = files.length > 0;

    if (!prompt && !hasImages) {
      files.forEach(f => fs.unlinkSync(f.path));
      return res.status(400).json({ error: { message: "prompt or image is required" }});
    }

    const account = await accountService.getIdleAccount();
    if (!account) {
      files.forEach(f => fs.unlinkSync(f.path));
      return res.status(503).json({ error: { message: 'All Dreamina accounts are busy or out of credits.' } });
    }

    let cliRatio = "1:1";
    if (req.body.ratio) {
      cliRatio = req.body.ratio;
    } else if (size) {
      if (size.includes('16:9')) cliRatio = "16:9";
      else if (size.includes('9:16')) cliRatio = "9:16";
      else if (size.includes('4:3')) cliRatio = "4:3";
      else if (size.includes('3:4')) cliRatio = "3:4";
      else if (size.includes('21:9')) cliRatio = "21:9";
      else if (size.includes('3:2')) cliRatio = "3:2";
      else if (size.includes('2:3')) cliRatio = "2:3";
    }
    
    let modelParam = model ? `--model_version=${model}` : "";
    let resParam = resolution_type ? `--resolution_type=${resolution_type}` : "";

    let command = "";
    let dbTaskType = "";
    if (hasImages) {
      const imagePathsStr = files.map(f => `"${process.cwd()}/${f.path}"`).join(',');
      command = `dreamina image2image --images ${imagePathsStr} --prompt="${prompt || ''}" --ratio=${cliRatio} ${modelParam} ${resParam} --poll=300`;
      dbTaskType = 'image2image';
    } else {
      command = `dreamina text2image --prompt="${prompt}" --ratio=${cliRatio} ${modelParam} ${resParam} --poll=300`;
      dbTaskType = 'text2image';
    }
    
    console.log(`[Jimeng Dispatcher] Executing: ${command}`);
    
    const dbTask = await prisma.task.create({
      data: { apiKeyId: (req as any).apiUserId, accountId: account.id, type: dbTaskType, prompt: prompt || '' }
    });

    let resultUrl = "";
    try {
      const { stdout } = await runJimengCommand(command, account.homeDir);
      resultUrl = extractResultUrl(stdout, 'image');
      await prisma.task.update({ where: { id: dbTask.id }, data: { status: 'SUCCESS', resultUrl } });
    } catch (cmdErr: any) {
      await prisma.task.update({ where: { id: dbTask.id }, data: { status: 'FAILED', errorMsg: cmdErr.message } });
      await accountService.releaseAccount(account.id, 'ERROR');
      files.forEach(f => fs.unlinkSync(f.path));
      return res.status(500).json({ error: { message: "Jimeng CLI failed: " + cmdErr.message } });
    }

    await accountService.releaseAccount(account.id, 'IDLE');
    files.forEach(f => fs.unlinkSync(f.path));

    return res.json({ created: Math.floor(Date.now() / 1000), data: [{ url: resultUrl }] });

  } catch (err: any) {
    if (req.files) (req.files as Express.Multer.File[]).forEach(f => fs.unlinkSync(f.path));
    res.status(500).json({ error: { message: err.message }});
  }
});


/**
 * POST /v1/videos/generations
 * 合并生视频功能 (文生视频 + 图生视频 + 全能参考 multimodal2video)
 */
router.post('/videos/generations', apiKeyAuth, upload.fields([
  { name: 'image', maxCount: 9 },
  { name: 'video', maxCount: 3 },
  { name: 'audio', maxCount: 3 }
]), async (req: Request, res: Response) => {
  const files = (req.files as { [fieldname: string]: Express.Multer.File[] }) || {};
  const imageFiles = files['image'] || [];
  const videoFiles = files['video'] || [];
  const audioFiles = files['audio'] || [];
  const allFiles = [...imageFiles, ...videoFiles, ...audioFiles];

  try {
    const { prompt, model, ratio, duration, video_resolution } = req.body;

    if (!prompt && allFiles.length === 0) {
      allFiles.forEach(f => fs.unlinkSync(f.path));
      return res.status(400).json({ error: { message: "prompt or media files are required" }});
    }

    const account = await accountService.getIdleAccount();
    if (!account) {
      allFiles.forEach(f => fs.unlinkSync(f.path));
      return res.status(503).json({ error: { message: 'All Dreamina accounts are busy or out of credits.' } });
    }

    const d = duration || 5;
    const mParam = model ? `--model_version=${model}` : "";
    const vrParam = video_resolution ? `--video_resolution=${video_resolution}` : "";
    const r = ratio || "16:9";
    
    let command = "";
    let dbTaskType = "";
    
    const isMultimodal = imageFiles.length > 1 || videoFiles.length > 0 || audioFiles.length > 0;

    if (isMultimodal) {
      // 全能参考视频
      const imgArgs = imageFiles.map(f => `--image="${process.cwd()}/${f.path}"`).join(' ');
      const vidArgs = videoFiles.map(f => `--video="${process.cwd()}/${f.path}"`).join(' ');
      const audArgs = audioFiles.map(f => `--audio="${process.cwd()}/${f.path}"`).join(' ');
      const mediaArgs = [imgArgs, vidArgs, audArgs].filter(Boolean).join(' ');
      const pParam = prompt ? `--prompt="${prompt}"` : "";
      
      command = `dreamina multimodal2video ${mediaArgs} ${pParam} ${mParam} --duration=${d} --ratio=${r} ${vrParam} --poll=300`;
      dbTaskType = 'multimodal2video';

    } else if (imageFiles.length === 1) {
      // 图生视频
      const imagePath = `"${process.cwd()}/${imageFiles[0].path}"`;
      command = `dreamina image2video --image=${imagePath} --prompt="${prompt || ''}" ${mParam} --duration=${d} ${vrParam} --poll=300`;
      dbTaskType = 'image2video';

    } else {
      // 文生视频
      command = `dreamina text2video --prompt="${prompt}" --ratio=${r} ${mParam} --duration=${d} ${vrParam} --poll=300`;
      dbTaskType = 'text2video';
    }
    
    console.log(`[Jimeng Dispatcher] Executing: ${command}`);
    
    const dbTask = await prisma.task.create({
      data: { apiKeyId: (req as any).apiUserId, accountId: account.id, type: dbTaskType, prompt: prompt || '' }
    });

    let resultUrl = "";

    try {
      const { stdout } = await runJimengCommand(command, account.homeDir);
      resultUrl = extractResultUrl(stdout, 'video');
      await prisma.task.update({ where: { id: dbTask.id }, data: { status: 'SUCCESS', resultUrl } });
    } catch (cmdErr: any) {
      await prisma.task.update({ where: { id: dbTask.id }, data: { status: 'FAILED', errorMsg: cmdErr.message } });
      await accountService.releaseAccount(account.id, 'ERROR');
      allFiles.forEach(f => { if (fs.existsSync(f.path)) fs.unlinkSync(f.path); });
      return res.status(500).json({ error: { message: "Jimeng CLI failed: " + cmdErr.message } });
    }

    await accountService.releaseAccount(account.id, 'IDLE');
    allFiles.forEach(f => { if (fs.existsSync(f.path)) fs.unlinkSync(f.path); });

    return res.json({ created: Math.floor(Date.now() / 1000), data: [{ url: resultUrl }] });

  } catch (err: any) {
    allFiles.forEach(f => { if (fs.existsSync(f.path)) fs.unlinkSync(f.path); });
    res.status(500).json({ error: { message: err.message }});
  }
});

export default router;
